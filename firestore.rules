rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function adminDoc(uid) {
      return get(/databases/$(database)/documents/systemAdmins/$(uid));
    }

    function isActiveSystemAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/systemAdmins/$(request.auth.uid))
        && adminDoc(request.auth.uid).data.isActive == true;
    }

    function isSuperAdmin() {
      return isActiveSystemAdmin()
        && adminDoc(request.auth.uid).data.role == 'super_admin';
    }

    match /systemAdmins/{adminId} {
      allow read: if (isSelf(adminId) && resource.data.isActive == true) || isSuperAdmin();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (
          isSelf(adminId)
          && resource.data.isActive == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastLogin',
            'updatedAt'
          ])
        );
    }

    match /{document=**} {
      allow read, write: if isActiveSystemAdmin();
    }
  }
}
